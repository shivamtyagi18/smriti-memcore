{
  "smriti": {
    "command": "/path/to/smriti-memory/.venv/bin/python3",
    "args": ["-m", "smriti.integrations.mcp_server"],
    "env": {
      "PYTHONPATH": "/path/to/smriti-memory",
      "SMRITI_STORAGE_PATH": "~/.smriti/global",
      "SMRITI_LLM_MODEL": "mistral",
      "SMRITI_LLM_API_KEY": ""
    }
  }
}
